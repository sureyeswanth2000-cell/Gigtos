rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }

    // Check if the current user is a superadmin (global access)
    function isSuperAdmin() {
      return isLoggedIn() &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == "superadmin";
    }

    // Check if the current user is an admin of any level
    function isAdmin() {
      return isLoggedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function currentAdminData() {
      return get(/databases/$(database)/documents/admins/$(request.auth.uid)).data;
    }

    function isRegionLead() {
      return isAdmin() && currentAdminData().role == "regionLead";
    }

    function isWorkerOwnerRole() {
      return isAdmin() &&
        currentAdminData().role != "regionLead";
    }

    // New: Check if the current admin is the parent of another admin (to support hierarchy)
    function isParentOf(targetAdminId) {
      let adminData = get(/databases/$(database)/documents/admins/$(request.auth.uid)).data;
      let targetData = get(/databases/$(database)/documents/admins/$(targetAdminId)).data;
      return isAdmin() && (
        adminData.role == "superadmin" || // Superadmin is parent to everyone
        targetData.parentAdminId == request.auth.uid // Direct parent-child link
      );
    }

    /* ============================
       USERS COLLECTION
    ============================ */
    match /users/{userId} {
      // Users can only manage their own profile; superadmins can read all
      allow read: if isLoggedIn() && (request.auth.uid == userId || isSuperAdmin());
      allow write: if isLoggedIn() && request.auth.uid == userId;
    }

    match /users_by_phone/{phoneNumber} {
      // Public read for login verification; strict write for specific phone owner
      allow read: if true;
      allow create, update: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.phone == phoneNumber;
      allow delete: if false;
    }

    match /workers_by_phone/{phoneNumber} {
      // Public read allows phone->email lookup for worker login.
      allow read: if true;

      // Admin hierarchy can maintain worker phone index.
      // Worker can only update their own mapping after activation.
      allow create, update: if isAdmin() || (
        request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.phone == phoneNumber
      );

      allow delete: if false;
    }

    match /worker_auth/{workerUid} {
      // Worker reads own profile; admins can read for support.
      allow read: if isLoggedIn() && (
        request.auth.uid == workerUid || isAdmin()
      );

      // Worker creates/updates own auth profile; admins can maintain it too.
      allow create, update: if isLoggedIn() && (
        request.auth.uid == workerUid || isAdmin()
      );

      allow delete: if isSuperAdmin();
    }

    /* ============================
       BOOKINGS COLLECTION
    ============================ */
    match /bookings/{bookingId} {

      // CREATE: user creates their own booking with a pending status
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.phone != null
        && request.resource.data.customerName != null
        && request.resource.data.serviceType != null
        && (request.resource.data.status == "pending" || request.resource.data.status == "scheduled")
        && request.resource.data.createdAt != null;

      // READ: accessible by owner, the assigning admin, or their parent admins
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid
        || (isAdmin() && resource.data.status in ['pending', 'scheduled', 'quoted'])
        || resource.data.adminId == request.auth.uid
        || (resource.data.adminId != null && isParentOf(resource.data.adminId))
        || isSuperAdmin()
      );

      // UPDATE — Spark mode support:
      // Allow owner/admin client-side transitions because callable functions may be unavailable on free tier.
      allow update: if request.auth != null && (
        (
          resource.data.userId == request.auth.uid &&
          request.resource.data.userId == request.auth.uid
        )
        ||
        (
          isAdmin() && (
            resource.data.adminId == request.auth.uid
            || resource.data.status in ['pending', 'scheduled', 'quoted']
            || isSuperAdmin()
          )
        )
      );

      // Client-side deletions are strictly prohibited
      allow delete: if false;
    }

    /* ============================
       CHAT SUBCOLLECTION
    ============================ */
    match /bookings/{bookingId}/chat/{messageId} {
      // Chat is private to user, assigned admin, and hierarchically higher admins
      allow read: if isLoggedIn() && (
        get(/databases/$(database)/documents/bookings/$(bookingId)).data.userId == request.auth.uid
        || get(/databases/$(database)/documents/bookings/$(bookingId)).data.adminId == request.auth.uid
        || (get(/databases/$(database)/documents/bookings/$(bookingId)).data.adminId != null && isParentOf(get(/databases/$(database)/documents/bookings/$(bookingId)).data.adminId))
        || isSuperAdmin()
      );
      // Only authorized parties can send messages
      allow create: if isLoggedIn() && (
        request.resource.data.senderId == request.auth.uid
        && (
          get(/databases/$(database)/documents/bookings/$(bookingId)).data.userId == request.auth.uid ||
          get(/databases/$(database)/documents/bookings/$(bookingId)).data.adminId == request.auth.uid ||
          isSuperAdmin()
        )
      );
      allow update, delete: if false;
    }

    /* ============================
       ACTIVITY LOGS
    ============================ */
    match /activity_logs/{logId} {
      // Action logs MUST go through secure backend callable functions now.
      allow create: if false;

      // Logs are viewable by admins and the specific booking owner
      allow read: if isLoggedIn() && (
        isAdmin()
        || (
          exists(/databases/$(database)/documents/bookings/$(resource.data.bookingId))
          && get(/databases/$(database)/documents/bookings/$(resource.data.bookingId)).data.userId == request.auth.uid
        )
      );

      allow update, delete: if false;
    }

    /* ============================
       ADMINS COLLECTION
    ============================ */
    match /admins/{adminId} {
      // An admin can read their own profile, and higher-level admins can read child profiles
      // SuperAdmin can read ALL admin profiles (for region performance overview)
      // Also allow reading regionLead profiles for dropdown/assignment selection
      allow read: if isLoggedIn() && (
        request.auth.uid == adminId 
        || isParentOf(adminId) 
        || isSuperAdmin()
        || resource.data.role == "regionLead"  // ✅ Allow all admins to see region leads for assignment
      );
      // Hierarchical provisioning:
      // - Superadmin can create any admin
      // - RegionLead can create child admins (mason role) under themselves
      // - TEMPORARY: Allow authenticated user to create their own admin doc (for initial superadmin setup)
      allow create: if isSuperAdmin() || (
        isAdmin()
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == "regionLead"
        && request.resource.data.role == "mason"
        && request.resource.data.parentAdminId == request.auth.uid
      ) || (
        isLoggedIn() 
        && request.auth.uid == adminId
        && !exists(/databases/$(database)/documents/admins/$(adminId))
      );
      allow delete: if isSuperAdmin();
      // Admins can update their own profile, superadmin can update any admin
      // This allows superadmin to set regionStatus, probationStatus etc.
      allow update: if isAdmin() && (request.auth.uid == adminId || isSuperAdmin());
    }

    /* ============================
       GIG WORKERS COLLECTION
    ============================ */
    match /gig_workers/{workerId} {
      // Workers are visible to their managing admin and the entire hierarchy above them
      allow read: if isLoggedIn() && (
        workerId == request.auth.uid ||
        resource.data.adminId == request.auth.uid ||
        (isRegionLead()
          && resource.data.approvalStatus == "pending"
          && resource.data.adminId in [null, ""]
          && resource.data.area == currentAdminData().areaName) ||
        (resource.data.adminId != null && isParentOf(resource.data.adminId)) ||
        isSuperAdmin()
      );
      // Admin/Mason create workers; region leads only monitor.
      // Workers can self-register in pending state and must be approved by region lead.
      allow create: if (
        isWorkerOwnerRole() && request.resource.data.adminId == request.auth.uid
      ) || (
        isLoggedIn()
        && workerId == request.auth.uid
        && request.resource.data.adminId in [null, ""]
        && request.resource.data.approvalStatus == "pending"
        && request.resource.data.status == "inactive"
      );
      // Allow admin owner or parent to update; superadmin can set fraud flags
      allow update: if isLoggedIn() && (
        workerId == request.auth.uid ||
        resource.data.adminId == request.auth.uid ||
        (isRegionLead()
          && resource.data.approvalStatus == "pending"
          && resource.data.adminId in [null, ""]
          && resource.data.area == currentAdminData().areaName) ||
        isParentOf(resource.data.adminId) ||
        isSuperAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    /* ============================
       CASHBACKS COLLECTION
    ============================ */
    match /cashbacks/{cashbackId} {
      // Users can read their own cashbacks
      allow read: if isLoggedIn() && (
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
      // Only admin SDK (Cloud Functions) creates/updates cashbacks
      // Client-side writes are prohibited
      allow create, update, delete: if false;
    }

    /* ============================
       ADMIN ALERTS COLLECTION
    ============================ */
    match /admin_alerts/{alertId} {
      // Region lead/admin sees own alerts; superadmin can inspect all.
      allow read: if isLoggedIn() && (
        resource.data.adminId == request.auth.uid || isSuperAdmin()
      );

      // Admin can mark own alert as read/closed; writes from backend are unrestricted by rules via Admin SDK.
      allow update: if isLoggedIn() && resource.data.adminId == request.auth.uid;

      // No direct client-side create/delete for alert integrity.
      allow create, delete: if false;
    }

  }
}
