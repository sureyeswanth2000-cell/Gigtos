rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }

    // Check if the current user is a superadmin (global access)
    function isSuperAdmin() {
      return isLoggedIn() &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == "superadmin";
    }

    // Check if the current user is an admin of any level
    function isAdmin() {
      return isLoggedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // New: Check if the current admin is the parent of another admin (to support hierarchy)
    function isParentOf(targetAdminId) {
      let adminData = get(/databases/$(database)/documents/admins/$(request.auth.uid)).data;
      let targetData = get(/databases/$(database)/documents/admins/$(targetAdminId)).data;
      return isAdmin() && (
        adminData.role == "superadmin" || // Superadmin is parent to everyone
        targetData.parentAdminId == request.auth.uid // Direct parent-child link
      );
    }

    /* ============================
       USERS COLLECTION
    ============================ */
    match /users/{userId} {
      // Users can only manage their own profile; superadmins can read all
      allow read: if isLoggedIn() && (request.auth.uid == userId || isSuperAdmin());
      allow write: if isLoggedIn() && request.auth.uid == userId;
    }

    match /users_by_phone/{phoneNumber} {
      // Public read for login verification; strict write for specific phone owner
      allow read: if true;
      allow create, update: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.phone == phoneNumber;
      allow delete: if false;
    }

    /* ============================
       BOOKINGS COLLECTION
    ============================ */
    match /bookings/{bookingId} {

      // CREATE: user creates their own booking with a pending status
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.phone != null
        && request.resource.data.customerName != null
        && request.resource.data.serviceType != null
        && (request.resource.data.status == "pending" || request.resource.data.status == "scheduled")
        && request.resource.data.createdAt != null;

      // READ: accessible by owner, the assigning admin, their parent admins, or
      // any admin for unassigned (pending/scheduled) bookings — all admins must
      // see open requests to participate in the bidding and assignment workflow.
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid
        || resource.data.adminId == request.auth.uid
        || (resource.data.adminId != null && isParentOf(resource.data.adminId))
        || isSuperAdmin()
        || (isAdmin() && resource.data.adminId == null)
      );

      // UPDATE — Enforce Backend Only for state changes.
      // Users can ONLY edit simple fields (address, phone) while pending/scheduled.
      // ALL state transitions (quotes, assigns, completes, disputes) MUST use Cloud Functions.
      allow update: if request.auth != null && (
        resource.data.userId == request.auth.uid &&
        (resource.data.status == 'pending' || resource.data.status == 'scheduled') &&
        request.resource.data.status == resource.data.status &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['address', 'phone', 'updatedAt', 'userId'])
      );

      // Client-side deletions are strictly prohibited
      allow delete: if false;
    }

    /* ============================
       CHAT SUBCOLLECTION
    ============================ */
    match /bookings/{bookingId}/chat/{messageId} {
      // Chat is private to user, assigned admin, and hierarchically higher admins
      allow read: if isLoggedIn() && (
        get(/databases/$(database)/documents/bookings/$(bookingId)).data.userId == request.auth.uid
        || get(/databases/$(database)/documents/bookings/$(bookingId)).data.adminId == request.auth.uid
        || (get(/databases/$(database)/documents/bookings/$(bookingId)).data.adminId != null && isParentOf(get(/databases/$(database)/documents/bookings/$(bookingId)).data.adminId))
        || isSuperAdmin()
      );
      // Only authorized parties can send messages
      allow create: if isLoggedIn() && (
        request.resource.data.senderId == request.auth.uid
        && (
          get(/databases/$(database)/documents/bookings/$(bookingId)).data.userId == request.auth.uid ||
          get(/databases/$(database)/documents/bookings/$(bookingId)).data.adminId == request.auth.uid ||
          isSuperAdmin()
        )
      );
      allow update, delete: if false;
    }

    /* ============================
       ACTIVITY LOGS
    ============================ */
    match /activity_logs/{logId} {
      // Action logs MUST go through secure backend callable functions now.
      allow create: if false;

      // Logs are viewable by admins and the specific booking owner
      allow read: if isLoggedIn() && (
        isAdmin()
        || (
          exists(/databases/$(database)/documents/bookings/$(resource.data.bookingId))
          && get(/databases/$(database)/documents/bookings/$(resource.data.bookingId)).data.userId == request.auth.uid
        )
      );

      allow update, delete: if false;
    }

    /* ============================
       ADMINS COLLECTION
    ============================ */
    match /admins/{adminId} {
      // An admin can read their own profile, and higher-level admins can read child profiles
      // SuperAdmin can read ALL admin profiles (for region performance overview)
      allow read: if isLoggedIn() && (request.auth.uid == adminId || isParentOf(adminId) || isSuperAdmin());
      // Hierarchical provisioning (SuperAdmin only for root, Parents for local)
      allow create, delete: if isSuperAdmin();
      // Admins can update their own profile, superadmin can update any admin
      // This allows superadmin to set regionStatus, probationStatus etc.
      allow update: if isAdmin() && (request.auth.uid == adminId || isSuperAdmin());
    }

    /* ============================
       GIG WORKERS COLLECTION
    ============================ */
    match /gig_workers/{workerId} {
      // Workers are visible to their managing admin, the entire hierarchy above
      // them, and superadmins (who see all workers across all regions).
      allow read: if isLoggedIn() && (
        resource.data.adminId == request.auth.uid ||
        (resource.data.adminId != null && isParentOf(resource.data.adminId)) ||
        isSuperAdmin()
      );
      // Local admins create workers; parents manage them
      allow create: if isAdmin() && request.resource.data.adminId == request.auth.uid;
      // Allow admin owner or parent to update; superadmin can set fraud flags
      allow update: if isLoggedIn() && (
        resource.data.adminId == request.auth.uid ||
        isParentOf(resource.data.adminId) ||
        isSuperAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    /* ============================
       CASHBACKS COLLECTION
    ============================ */
    match /cashbacks/{cashbackId} {
      // Users can read their own cashbacks
      allow read: if isLoggedIn() && (
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
      // Only admin SDK (Cloud Functions) creates/updates cashbacks
      // Client-side writes are prohibited
      allow create, update, delete: if false;
    }

  }
}
