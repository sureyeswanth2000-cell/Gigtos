rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isLoggedIn() &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == "superadmin";
    }

    function isAdmin() {
      return isLoggedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    /* ============================
       USERS COLLECTION
    ============================ */
    match /users/{userId} {
      allow read, write: if isLoggedIn() && request.auth.uid == userId;
    }

    match /users_by_phone/{phoneNumber} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.phone == phoneNumber;
      allow delete: if false;
    }

    /* ============================
       BOOKINGS COLLECTION
    ============================ */
    match /bookings/{bookingId} {

      // CREATE: user creates their own booking
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.phone != null
        && request.resource.data.customerName != null
        && request.resource.data.serviceType != null
        && request.resource.data.status == "pending"
        && request.resource.data.createdAt != null;

      // READ: owner or any admin
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid
        || isAdmin()
      );

      // UPDATE — all allowed cases combined
      allow update: if request.auth != null && (

        // 1) User cancels their own PENDING booking
        (
          resource.data.userId == request.auth.uid
          && resource.data.status == 'pending'
          && request.resource.data.status == 'cancelled'
        )

        // 2) User confirms completion when awaiting_confirmation
        || (
          resource.data.userId == request.auth.uid
          && resource.data.status == 'awaiting_confirmation'
          && request.resource.data.status == 'completed'
        )

        // 3) User edits address/phone on a pending booking
        || (
          resource.data.userId == request.auth.uid
          && resource.data.status == 'pending'
          && request.resource.data.status == 'pending'
        )

        // 4) User submits rating on completed booking
        || (
          resource.data.userId == request.auth.uid
          && resource.data.status == 'completed'
          && request.resource.data.rating is number
          && request.resource.data.rating >= 1
          && request.resource.data.rating <= 5
        )

        // 5) User raises a dispute on completed booking
        || (
          resource.data.userId == request.auth.uid
          && resource.data.status == 'completed'
          && request.resource.data.keys().hasAll(['dispute'])
        )

        // 6) Admin manages lifecycle (cannot change userId)
        || (
          isAdmin()
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.createdAt == resource.data.createdAt
        )
      );

      // No client-side deletes
      allow delete: if false;
    }

    /* ============================
       CHAT SUBCOLLECTION
    ============================ */
    match /bookings/{bookingId}/chat/{messageId} {
      allow read: if isLoggedIn() && (
        get(/databases/$(database)/documents/bookings/$(bookingId)).data.userId == request.auth.uid
        || isAdmin()
      );
      allow create: if isLoggedIn() && (
        request.resource.data.senderId == request.auth.uid
        && (get(/databases/$(database)/documents/bookings/$(bookingId)).data.userId == request.auth.uid || isAdmin())
      );
      allow update, delete: if false;
    }

    /* ============================
       ACTIVITY LOGS
    ============================ */
    match /activity_logs/{logId} {
      // Any authenticated user (user or admin) can create a log entry
      allow create: if isLoggedIn()
        && request.resource.data.actorId == request.auth.uid
        && request.resource.data.bookingId != null;

      // Admins can read all logs; users can read logs for their own bookings
      allow read: if isLoggedIn() && (
        isAdmin()
        || (
          exists(/databases/$(database)/documents/bookings/$(resource.data.bookingId))
          && get(/databases/$(database)/documents/bookings/$(resource.data.bookingId)).data.userId == request.auth.uid
        )
      );

      // No updates or deletes
      allow update, delete: if false;
    }

    /* ============================
       ADMINS COLLECTION
    ============================ */
    match /admins/{adminId} {
      allow read: if isLoggedIn() && (request.auth.uid == adminId || isSuperAdmin());
      allow create, delete: if isSuperAdmin();
      allow update: if false;
    }

    /* ============================
       GIG WORKERS COLLECTION
    ============================ */
    match /gig_workers/{workerId} {
      allow read: if isLoggedIn() && (isSuperAdmin() || resource.data.adminId == request.auth.uid || isAdmin());
      allow create: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && request.resource.data.adminId == request.auth.uid;
      allow update: if isLoggedIn() && (
        isSuperAdmin() || resource.data.adminId == request.auth.uid
      ) && request.resource.data.adminId == resource.data.adminId;
      allow delete: if isSuperAdmin();
    }

  }
}
