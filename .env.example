# =============================================================================
# .env.example — Environment template for Gigtos CI/CD scripts
# =============================================================================
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file to source control!
#
#   cp .env.example .env
#   # edit .env with your credentials
# =============================================================================

# ── Firebase / Google Cloud ───────────────────────────────────────────────────
# Your Firebase project ID (find it in the Firebase console → Project settings)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Cloud Functions region (default: us-central1)
FIREBASE_REGION=us-central1

# ── GitHub ────────────────────────────────────────────────────────────────────
# Personal access token or fine-grained PAT with repo + workflow scopes
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Email — Gmail / Nodemailer ────────────────────────────────────────────────
# The Gmail address used by the Cloud Functions for outbound notifications
GMAIL_USER=you@gmail.com

# A Gmail "app password" (NOT your account password).
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_PASS=xxxx-xxxx-xxxx-xxxx

# ── SMS — Twilio ──────────────────────────────────────────────────────────────
# Account SID — starts with AC...
# Find it at: https://console.twilio.com
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Auth Token (keep this secret!)
TWILIO_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Twilio phone number in E.164 format (e.g. +12025551234)
TWILIO_PHONE=+12025551234

# ── Test credentials ──────────────────────────────────────────────────────────
# Used only by the automated test suite; use Twilio magic numbers for SMS tests.
# See: https://www.twilio.com/docs/iam/test-credentials
TEST_USER_EMAIL=test-user@example.com
TEST_USER_PHONE=+15005550006
TEST_ADMIN_EMAIL=test-admin@example.com

# ── Slack (optional) ──────────────────────────────────────────────────────────
# Incoming Webhook URL for deployment notifications.
# Leave blank to disable Slack notifications.
# Create a webhook at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# ── Script behaviour (optional overrides) ────────────────────────────────────
# Set to "true" to preview actions without executing them
DRY_RUN=false

# Set to "true" to skip the test suite during deployment
SKIP_TESTS=false

# Set to "true" for verbose output
VERBOSE=false
