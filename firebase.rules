rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isLoggedIn() &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == "superadmin";
    }

    function isAdmin() {
      return isLoggedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    /* ============================
       USERS COLLECTION
    ============================ */
    match /users/{userId} {
      allow read, write: if isLoggedIn() && request.auth.uid == userId;
    }

    // auxiliary lookup collection used by phone-based login
    match /users_by_phone/{phoneNumber} {
      // anyone (even unauthenticated) may read a mapping so the client
      // can resolve a phone number to an auth UID/email during login.
      allow read: if true;

      // create/update only allowed by the authenticated user whose UID is
      // stored in the document (prevents one user impersonating another).
      allow create, update: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.phone == phoneNumber;
      // deletion not needed from client
      allow delete: if false;
    }

    /* ============================
       BOOKINGS COLLECTION
    ============================ */
    match /bookings/{bookingId} {

      // CREATE: user may create their own booking with status pending
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.phone != null
        && request.resource.data.customerName != null
        && request.resource.data.serviceType != null
        && request.resource.data.status == "pending"
        && request.resource.data.createdAt != null;

      // READ: owner or any admin can read
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid
        || isAdmin()
      );

      // UPDATE: allowed cases
      allow update: if request.auth != null && (

        // 1) User can cancel their own pending booking
        (
          resource.data.userId == request.auth.uid
          && resource.data.status == 'pending'
          && request.resource.data.status == 'cancelled'
          && request.resource.data.userId == resource.data.userId
        )

        // 2) User confirms completion when awaiting_confirmation
        || (
          resource.data.userId == request.auth.uid
          && resource.data.status == 'awaiting_confirmation'
          && request.resource.data.status == 'completed'
          && request.resource.data.userId == resource.data.userId
        )

        // 3) Admins may update lifecycle fields but cannot change ownership fields
        || (
          isAdmin()
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.phone == resource.data.phone
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.updatedAt != null
        )
      );

      // Prevent client-side deletes
      allow delete: if false;
    }

    /* ============================
       CHAT SUBCOLLECTION (per booking)
    ============================ */
    match /bookings/{bookingId}/chat/{messageId} {
      // users may read any chat for bookings they belong to; admins may read all
      allow read: if isLoggedIn() && (
        resource.data.senderId == request.auth.uid
        || get(/databases/$(database)/documents/bookings/$(bookingId)).data.userId == request.auth.uid
        || isAdmin()
      );

      // write: only participants (user / admin) may post, cannot forge another sender
      allow create: if isLoggedIn() && (
        request.resource.data.senderId == request.auth.uid
        && (get(/databases/$(database)/documents/bookings/$(bookingId)).data.userId == request.auth.uid || isAdmin())
      );

      // updates/deletes not allowed from client
      allow update, delete: if false;
    }

    /* ============================
       RATINGS & REVIEWS
    ============================ */
    // rating and review fields are stored on booking documents. allow the
    // user to add them only after completion, admins cannot modify.
    match /bookings/{bookingId} {
      allow update: if request.auth != null &&
        resource.data.userId == request.auth.uid &&
        resource.data.status == 'completed' &&
        request.resource.data.rating is number &&
        request.resource.data.rating >= 1 &&
        request.resource.data.rating <= 5 &&
        (request.resource.data.review is string || request.resource.data.review == resource.data.review);
    }

    /* ============================
       ADMINS COLLECTION
    ============================ */
    match /admins/{adminId} {
      allow read: if isLoggedIn() && (request.auth.uid == adminId || isSuperAdmin());
      allow create, delete: if isSuperAdmin();
      allow update: if false;
    }

    /* ============================
       GIG WORKERS COLLECTION
    ============================ */
    match /gig_workers/{workerId} {

      // Read: only superadmin or the owning admin can read worker details
      allow read: if isLoggedIn() && (isSuperAdmin() || resource.data.adminId == request.auth.uid);

      // Create: only authenticated admin may create and must set adminId to their uid
      allow create: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && request.resource.data.adminId == request.auth.uid;

      // Update: only superadmin or owner admin; prevent changing adminId
      allow update: if isLoggedIn() && (
        isSuperAdmin() || resource.data.adminId == request.auth.uid
      ) && request.resource.data.adminId == resource.data.adminId;

      // Delete: only superadmin
      allow delete: if isSuperAdmin();
    }

  }
}
