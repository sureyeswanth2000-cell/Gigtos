rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Users can read and write only their own files
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Booking attachments: accessible by authenticated users involved in the booking
    // (further access control enforced server-side via Cloud Functions)
    match /bookings/{bookingId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
