# .env.example — Environment variable template for Gigtos
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.

# ─── Firebase ────────────────────────────────────────────────────────────────
# Your Firebase project ID (visible in the Firebase Console URL)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Cloud Functions region (default: us-central1)
FIREBASE_REGION=us-central1

# Firebase CI token — generate with: firebase login:ci
# Required for non-interactive deployments (CI/CD, scripts)
FIREBASE_TOKEN=your-firebase-ci-token

# ─── Email — Gmail (via Nodemailer) ──────────────────────────────────────────
# Gmail account used to send booking notifications
GMAIL_USER=your-email@gmail.com

# Gmail App Password (NOT your regular password)
# Create one at: https://myaccount.google.com/apppasswords
GMAIL_PASS=your-gmail-app-password

# ─── Email — SendGrid (alternative to Gmail) ─────────────────────────────────
# SendGrid API key — create at: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your-sendgrid-api-key

# Sender email address verified in SendGrid
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ─── SMS — Twilio ─────────────────────────────────────────────────────────────
# Twilio Account SID — find at: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio Auth Token — find at: https://console.twilio.com
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# Twilio phone number (must be a verified Twilio number, E.164 format)
TWILIO_PHONE_NUMBER=+1234567890

# ─── OTP Security ─────────────────────────────────────────────────────────────
# Secret key for HMAC-SHA256 OTP hashing — use a long random string
# Set via Firebase Functions config: firebase functions:config:set otp.secret="<value>"
OTP_HMAC_SECRET=replace-with-long-random-secret

# ─── GitHub CLI (optional — for deploy.sh PR merge step) ─────────────────────
# Personal Access Token with repo scope — create at: https://github.com/settings/tokens
# Required only if 'gh' CLI is not already authenticated
GITHUB_TOKEN=ghp_your-github-personal-access-token
