# React app environment variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local or .env to source control.

# reCAPTCHA v3 site key for Firebase App Check
# Obtain from Firebase Console → App Check → Register your web app
REACT_APP_RECAPTCHA_SITE_KEY=

# Firebase App Check debug token for local development
# Obtain from Firebase Console → App Check → Apps → Debug tokens
# Only used in NODE_ENV != 'production'
REACT_APP_APPCHECK_DEBUG_TOKEN=
