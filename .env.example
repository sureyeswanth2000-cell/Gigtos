# Gigtos – Environment Configuration Template
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to source control.

# ── Firebase ──────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=gigtos-prod
FIREBASE_REGION=us-central1

# ── GitHub ────────────────────────────────────────────────────────────────────
# Personal Access Token with repo + workflow scopes
GITHUB_TOKEN=ghp_xxxxx

# ── Email (Gmail + App Password) ──────────────────────────────────────────────
GMAIL_USER=your-email@gmail.com
GMAIL_PASS=your-app-password

# ── Twilio (SMS) ──────────────────────────────────────────────────────────────
TWILIO_SID=ACxxxxx
TWILIO_TOKEN=your-twilio-auth-token
TWILIO_PHONE=+1234567890

# ── Script behaviour ──────────────────────────────────────────────────────────
# Set to 'true' to print commands without executing them
DRY_RUN=false

# Set to 'true' to enable verbose/debug output
VERBOSE=false

# Set to 'true' to skip the automated test suite during deployment
SKIP_TESTS=false
